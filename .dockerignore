# Azure CLI's ACR packer does not normalize a trailing slash on directory
# rules. Keep directory names slashless so local build-only content is not
# uploaded as remote build context.
.venv
.git
.env*
frontend
workspace
infra
docs
tests
.codex
.claude
.github
.local-runs
.mvp-artifacts
.uv-cache
evidence
ida-reference
incoming
workspace-debug
scripts
playwright-report
coverage
__pycache__
.pytest_cache
.ruff_cache
.mypy_cache
*.pyc
node_modules
logs
screenshots
screenshots-*
test-results
sample_data
backend.log
review
sweep-results
