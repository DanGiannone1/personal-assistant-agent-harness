AZURE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/openai/v1/
AZURE_DEPLOYMENT=your-deployment-name
# Azure OpenAI API version (default 2024-10-21 if unset)
# AZURE_API_VERSION=2024-10-21

# Session-runtime endpoint. dev.py overrides this with its configured loopback runtime URL.
POOL_MANAGEMENT_ENDPOINT=http://localhost:8080
# Optional collision-safe local stack. When CSA_LOCAL_RUN_ID is set, dev.py uses
# .local-runs/<id>/ and .mvp-artifacts/<id>; its Cosmos database/container names
# must include the same id and a demo/local marker.
# CSA_LOCAL_RUN_ID=example-run
# CSA_RUNTIME_PORT=8080
# CSA_API_PORT=8000
# CSA_FRONTEND_PORT=3000
# For HTTPS runtime calls, set this to the dedicated runtime API audience. The
# orchestrator obtains <audience>/.default through its managed identity.
# POOL_AUTH_AUDIENCE=api://<runtime-api-client-id>
# Legacy token forwarding is disabled by default: the runtime owns its Azure
# OpenAI managed identity. Set true only for an explicitly approved migration.
# FORWARD_AZURE_OPENAI_TOKEN=false

# Runtime workload authentication. Local uses off; the Entra release requires
# all three identifiers and an application role issued to the orchestrator.
# WORKLOAD_AUTH_MODE=off
# WORKLOAD_ENTRA_TENANT_ID=
# WORKLOAD_ENTRA_AUDIENCE=api://<runtime-api-client-id>
# WORKLOAD_ENTRA_CALLER_OBJECT_ID=<orchestrator-managed-identity-object-id>
# WORKLOAD_ENTRA_REQUIRED_ROLE=invoke

# Frontend URL for CORS in production (e.g. https://your-app.azurecontainerapps.io)
FRONTEND_URL=

# Identity mode — every instance chooses exactly one value. Local/CI test stacks
# use demo; the shared release uses entra. Do not configure both credential paths.
IDENTITY_MODE=demo
# Required only for demo mode. Supply a local/test secret; never commit a value.
DEMO_PASSWORD=
# Required for entra mode. The audience may come from ENTRA_API_CLIENT_ID or the
# explicit comma-separated ENTRA_ALLOWED_AUDIENCES list.
# ENTRA_TENANT_ID=
# ENTRA_API_CLIENT_ID=
# ENTRA_ALLOWED_AUDIENCES=
# ENTRA_FRONTEND_CLIENT_ID=
# ENTRA_API_SCOPES=
# ENTRA_REDIRECT_URI=

# Session container settings
# AGENT_BACKEND defaults to deepagents. Set AGENT_BACKEND=copilot only for the local portability check.
# AGENT_BACKEND=deepagents
# CHAT_TIMEOUT_SECONDS=300   # Max seconds to wait for an agent turn (default: 300)
# LOG_AGENT_EVENTS=true      # Print structured agent loop events to terminal (local dev only)
# LOG_TRACE=true              # Write structured JSONL trace to ./logs/trace.jsonl (local dev only)
# LOG_RAW_SDK_EVENTS=true      # Write per-session raw agent SDK event stream JSONL files (local dev only)
# LOG_TRACE_DIR=./logs         # Shared trace directory for LOG_TRACE and LOG_RAW_SDK_EVENTS
# LOG_RAW_SDK_EVENTS_DIR=./logs # Optional: separate directory for raw agent SDK event stream JSONL files

# Azure Cosmos DB — current multi-user application state. It is required: startup
# fails loud when COSMOS_ENDPOINT is unset. Use a local emulator on a laptop; this
# repository does not start or wire that emulator for you.
# COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
# COSMOS_DATABASE=csa_workbench_demo
# COSMOS_CONTAINER=appstate
# COSMOS_KEY=<Cosmos-emulator key only; never use a production key>

# Reminder email delivery via Azure Communication Services (AAD auth, no keys).
# Off by default: with no ACS configuration, reminders stay in-app only. When both
# ACS values are set, the API app ticks a dispatch loop (REMINDER_DISPATCH=auto).
# Recipients are always identity-derived — Entra actors receive mail at their
# sign-in address; demo actors only at REMINDER_DEMO_EMAIL. Never a client value.
# ACS_EMAIL_ENDPOINT=https://<acs-name>.unitedstates.communication.azure.com
# ACS_SENDER_ADDRESS=DoNotReply@<guid>.azurecomm.net
# REMINDER_DISPATCH=auto      # auto | loop | off
# REMINDER_TICK_SECONDS=60
# REMINDER_DEMO_EMAIL=        # only address demo-actor reminders may go to (testing)

# Local durable Engagement artifact directory. Isolated dev.py runs override this
# with .mvp-artifacts/<CSA_LOCAL_RUN_ID>; the guarded reset refuses broad paths.
ARTIFACTS_DIR=.mvp-artifacts
# Required in the Entra release so Engagement artifact bytes use durable Blob
# storage instead of local runtime disk.
# ARTIFACTS_ACCOUNT=
# ARTIFACTS_CONTAINER=engagement-artifacts
