AZURE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/openai/v1/
AZURE_DEPLOYMENT=your-deployment-name

# ACA session pool management endpoint (local dev uses http://localhost:8080)
POOL_MANAGEMENT_ENDPOINT=http://localhost:8080

# Frontend URL for CORS in production (e.g. https://your-app.azurecontainerapps.io)
FRONTEND_URL=

# Document processing (required)
# ADLS Gen2: stores originals + converted markdown. Needs Storage Blob Data Contributor role.
ADLS_ACCOUNT_NAME=
ADLS_FILESYSTEM=documents
# Content Understanding: converts uploads to markdown via prebuilt-layout.
# Uses the same Foundry resource as AZURE_ENDPOINT — no separate endpoint needed.
#
# NOTE: grounding is tool-based — the agent reads the engagement's documents directly
# from the per-session workspace (list_documents + read_workspace_file). There is no
# Azure AI Search / vector retrieval layer in this MVP.

# IP restriction (optional — locks both container apps to a single IP)
# ALLOWED_IP=1.2.3.4/32

# App-level auth (optional — recommended for Azure)
# Create two app registrations:
# 1. A confidential/backend app for the API
# 2. A SPA app for the browser frontend
# Then set these values to require auth at the API and enable browser sign-in.
# API_AUTH_REQUIRED=true
# API_KEY=                  # Optional shared key for trusted local/dev callers
# ENTRA_TENANT_ID=
# ENTRA_API_CLIENT_ID=      # Backend/API app registration client ID
# ENTRA_ALLOWED_AUDIENCES=  # Optional comma-separated extra audiences
# ENTRA_FRONTEND_CLIENT_ID= # SPA app registration client ID
# ENTRA_API_SCOPES=         # Optional, defaults to api://<ENTRA_API_CLIENT_ID>/access_as_user
# ENTRA_REDIRECT_URI=       # defaults to https://<frontend-url> if omitted
#
# ACA Easy Auth (optional hardening)
# ENTRA_CLIENT_SECRET=      # Backend app registration client secret, only needed if enabling ACA Easy Auth
# APPLICATIONINSIGHTS_CONNECTION_STRING=   # Optional: if omitted, infra/deploy.sh provisions App Insights + Log Analytics automatically

# Session container settings
# CHAT_TIMEOUT_SECONDS=300   # Max seconds to wait for an agent turn (default: 300)
# LOG_AGENT_EVENTS=true      # Print structured agent loop events to terminal (local dev only)
# LOG_TRACE=true              # Write structured JSONL trace to ./logs/trace.jsonl (local dev only)
# LOG_RAW_SDK_EVENTS=true      # Write per-session raw Copilot SDK event stream JSONL files (local dev only)
# LOG_TRACE_DIR=./logs         # Shared trace directory for LOG_TRACE and LOG_RAW_SDK_EVENTS
# LOG_RAW_SDK_EVENTS_DIR=./logs # Optional: separate directory for raw Copilot SDK event stream JSONL files

# Azure Cosmos DB — per-session app state (tasks/events). AAD-only (no key):
# the app authenticates with DefaultAzureCredential (az login locally / managed
# identity in the ACA Sandbox). Grant the principal the Cosmos DB Built-in Data
# Contributor role on the account.
# COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
# COSMOS_DATABASE=flow
# COSMOS_CONTAINER=appstate
