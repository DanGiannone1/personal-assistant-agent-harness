# Rendered by install-profile.sh. Replace @CODEX_HOME@ only during installation.
# This profile is intentionally runtime-native and repository-neutral.

model = "gpt-5.6-sol"
model_reasoning_effort = "ultra"
model_instructions_file = "@CODEX_HOME@/PPEL.md"

[features]
multi_agent = true

[features.multi_agent_v2]
enabled = true
max_concurrent_threads_per_session = 13
tool_namespace = "ppel_agents"
hide_spawn_agent_metadata = false
non_code_mode_only = true

[agents]
max_depth = 2

[agents.luna]
description = "Read-only evidence worker with medium reasoning."
config_file = "@CODEX_HOME@/agents/luna.toml"

[agents.terra]
description = "Scoped implementation worker with high reasoning."
config_file = "@CODEX_HOME@/agents/terra.toml"

[agents.sol]
description = "Senior analysis and review worker with high reasoning."
config_file = "@CODEX_HOME@/agents/sol.toml"
